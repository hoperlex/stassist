# Переменные окружения Stassist. Скопируйте в .env (который в .gitignore, никогда не коммитьте)
# и заполните нужные значения. Схема и деление на «всегда обязательные» / «обязательные для
# функции» / degraded-режим — packages/shared/src/config.ts (см. §3 конвенций реализации,
# docs/roadmap/31-конвенции-реализации.md).
#
# Правило: в NODE_ENV=production отсутствие переменных для выбранной НЕ-stub подсистемы —
# падение процесса на старте (fail-fast). В development/test — подсистема просто в
# degraded-режиме, процесс поднимается, /healthz всё равно отвечает 200.

# ---------------------------------------------------------------------------
# Всегда обязательные (есть безопасные dev-дефолты в коде, но переопределите на стейдже/проде)
# ---------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
# Секрет для подписи cookie (мин. 16 символов). Сгенерируйте случайный на стейдже/проде,
# например: openssl rand -base64 48
COOKIE_SECRET=dev-insecure-cookie-secret-change-me-please-32
# Список разрешённых Origin для CORS через запятую.
CORS_ALLOWLIST=http://localhost:3000

# ---------------------------------------------------------------------------
# База данных (обязательна для функции; в production — обязательна безусловно)
# ---------------------------------------------------------------------------
# Чистый PostgreSQL DSN. Локально — docker-compose (postgres, образ pgvector/pgvector:pg15).
DATABASE_URL=postgres://stassist:stassist@localhost:5432/stassist
# ADR-8 (docs/architecture/21-техническая-архитектура.md §10): облачный Supabase — допустимая
# dev/стейдж-альтернатива с синтетическими данными (НЕ для прода с ПД россиян, см. 152-ФЗ).
DATABASE_URL_SUPABASE_STAGE=

# ---------------------------------------------------------------------------
# Object storage (S3-совместимое; MinIO локально, Yandex Object Storage на проде)
# ---------------------------------------------------------------------------
STORAGE=stub
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=stassist
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Почта (SMTP)
# ---------------------------------------------------------------------------
MAILER=stub
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@stassist.ru

# ---------------------------------------------------------------------------
# Геокодер (Nominatim)
# ---------------------------------------------------------------------------
GEOCODER=stub
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=stassist/1.0 (contact: {{ЗАПОЛНИТ ЗАКАЗЧИК}})

# ---------------------------------------------------------------------------
# Платежи (ЮKassa)
# ---------------------------------------------------------------------------
PAYMENTS=stub
YOOKASSA_SHOP_ID={{ЗАПОЛНИТ ЗАКАЗЧИК}}
YOOKASSA_SECRET_KEY={{ЗАПОЛНИТ ЗАКАЗЧИК}}

# ---------------------------------------------------------------------------
# LLM / эмбеддинги (см. docs/architecture/21-техническая-архитектура.md §4)
# ---------------------------------------------------------------------------
LLM_PROVIDER=stub
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
YANDEXGPT_API_KEY=
GIGACHAT_API_KEY=

EMBED_PROVIDER=stub

# ---------------------------------------------------------------------------
# docker-compose (только для локального/стейдж-стека, см. docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_USER=stassist
POSTGRES_PASSWORD=stassist
POSTGRES_DB=stassist
POSTGRES_PORT=5432
MINIO_ROOT_USER=stassist
MINIO_ROOT_PASSWORD=stassist123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Домен для caddy (TLS). Без реального домена — 'localhost' + самоподписанный tls internal
# (см. caddy/Caddyfile). На проде — реальный домен, тогда caddy сам получит сертификат Let's
# Encrypt.
CADDY_DOMAIN={{ЗАПОЛНИТ ЗАКАЗЧИК}}

# ---------------------------------------------------------------------------
# Деплой на стейдж/прод (CI, см. .github/workflows/ci.yml, job deploy-stage) — требует
# ручного шага заказчика: хост, ключ доступа, реестр образов.
# ---------------------------------------------------------------------------
STAGE_HOST={{ЗАПОЛНИТ ЗАКАЗЧИК}}
STAGE_DOMAIN={{ЗАПОЛНИТ ЗАКАЗЧИК}}
