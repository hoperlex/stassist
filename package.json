{
  "name": "stassist",
  "private": true,
  "version": "0.0.0",
  "description": "Stassist — русскоязычный астрологический портал (монорепозиторий)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "gate": "pnpm -r typecheck && pnpm -r lint && pnpm -r test:unit && pnpm -r build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx tools/db-migrate.ts",
    "db:seed": "tsx tools/db-seed.ts",
    "data:gen-vsop87": "tsx tools/gen-vsop87.ts",
    "data:gen-chiron": "tsx tools/gen-chiron.ts",
    "data:seed-calc-presets": "pnpm --filter @stassist/shared --filter @stassist/astro-core --filter @stassist/db build && node --experimental-strip-types tools/seed-calc-presets.ts",
    "data:seed-compat-pages": "pnpm --filter @stassist/shared build && node --experimental-strip-types tools/seed-compat-pages.ts",
    "data:corpus": "pnpm --filter @stassist/shared --filter @stassist/numerology-core --filter @stassist/llm build && node --experimental-strip-types tools/gen-corpus.ts",
    "data:stones": "pnpm --filter @stassist/shared build && node --experimental-strip-types tools/gen-stones.ts",
    "data:wiki": "pnpm --filter @stassist/shared --filter @stassist/numerology-core --filter @stassist/llm build && node --experimental-strip-types tools/gen-wiki.ts",
    "data:celebrities": "pnpm --filter @stassist/shared build && node --experimental-strip-types tools/gen-celebrities.ts",
    "data:horoscopes-backfill": "pnpm --filter @stassist/shared --filter @stassist/astro-core --filter @stassist/numerology-core --filter @stassist/db --filter @stassist/llm --filter @stassist/worker build && node --experimental-strip-types tools/data-horoscopes-backfill.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@stassist/db": "workspace:*",
    "@stassist/llm": "workspace:*",
    "@stassist/shared": "workspace:*",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "globals": "^15.14.0",
    "pg": "^8.22.0",
    "@types/pg": "^8.11.10",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.10.4",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.19.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
