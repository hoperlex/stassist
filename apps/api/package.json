{
  "name": "@stassist/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "build": "tsc -p tsconfig.build.json",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.1.1",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@stassist/astro-core": "workspace:*",
    "@stassist/db": "workspace:*",
    "@stassist/llm": "workspace:*",
    "@stassist/numerology-core": "workspace:*",
    "@stassist/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "^4.0.2",
    "hash-wasm": "^4.12.0",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "pino": "^9.6.0",
    "tsx": "^4.19.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
