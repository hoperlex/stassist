{
  "name": "@stassist/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist", "server"],
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint pages renderer server e2e playwright.config.ts",
    "build": "vite build",
    "test:unit": "vitest run",
    "test:e2e": "node -e \"if(!process.env.RUN_E2E){console.log('test:e2e: RUN_E2E не задан — пропускаю (см. §1 конвенций реализации)');process.exit(0)}process.exit(1)\" || playwright test"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.23.0",
    "@fastify/middie": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@stassist/shared": "workspace:*",
    "@stassist/ui": "workspace:*",
    "antd": "^5.29.3",
    "fastify": "^5.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "vike": "^0.4.260"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^7.0.3",
    "vite": "^7.3.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
