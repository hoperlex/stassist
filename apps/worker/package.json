{
  "name": "@stassist/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:prod": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "build": "tsc -p tsconfig.build.json",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@stassist/astro-core": "workspace:*",
    "@stassist/db": "workspace:*",
    "@stassist/shared": "workspace:*",
    "@stassist/ui": "workspace:*",
    "astronomy-engine": "^2.1.19",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
